---
import HeaderLink from "./HeaderLink.astro";
import { SITE_TITLE, BLOG_ENABLED } from "../consts";
---

<header transition:animate="fade">
  <nav>
    <a href="/" class="name-title">
      <!-- <h2><a href="/">{SITE_TITLE}</a></h2> -->

      <div class="nametag custom-font">
        <h2 class="fullname">Tor Halle-McIntyre</h2>
        <h2 class="shortname">Tor</h2>
      </div>
    </a>

    <div class="internal-links header-links">
      <HeaderLink href="/">About</HeaderLink>
      <HeaderLink href="/projects">Projects</HeaderLink>
      {BLOG_ENABLED ? <HeaderLink href="/blog">Blog</HeaderLink> : ""}
      <HeaderLink href="/archive">Gallery</HeaderLink>
    </div>
  </nav>
</header>
<style>
  header {
    margin: 0;
    margin-bottom: 1em;
    padding: 0 min(2em, 0);
    padding-top: 1ch;
    background: white;
    background-color: var(--background-colour);
    box-shadow: 0 2px 8px rgba(var(--black), 5%);
    border-bottom: 0.1em solid transparent;
    border-bottom-color: var(--accent);
    min-height: 7ch;
    align-content: center;
    filter: drop-shadow(0 0 0.75rem black);
  }
  .container {
  }
  h2 {
    margin: 0;
  }

  h2 a,
  h2 a.active {
    text-decoration: none;
    text-size-adjust: 2;
  }
  nav {
    display: flex;
    padding: 0 min(1rem, calc(100% - 64px));
    justify-content: left;
  }
  nav a {
    /* padding: 4em 0.5em; */
    color: var(--black);
    border-bottom: 4px solid transparent;
    text-decoration: none;
    align-content: center;
  }
  nav a.active {
    text-decoration: none;
    border-bottom-color: var(--accent);
  }
  .name-title {
    margin-right: auto;
    font-size: larger;
  }
  .header-spacer {
  }
  .internal-links {
    display: flex;
    gap: 1ch;
    margin-right: 4em;
  }
  .social-links,
  .social-links a {
    display: flex;
  }
  .nametag {
    display: flex;
  }
  .fullname {
    display: block;
  }
  .shortname {
    display: none;
    /* font-size: 1.6em; */
    /* font-variant: small-caps; */
  }
  @media (max-width: 720px) {
    .social-links {
      display: none;
    }
  }
  @media (max-width: 50ch) {
    .shortname {
      display: block;
    }
    .fullname {
      display: none;
    }
  }
</style>
