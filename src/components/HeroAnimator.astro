---
import { Image } from "astro:assets";

import ImgBackground from "../content/decor/ui_icon_wip3d_frame_cube3_hollow.png";
import ImgForeground from "../content/decor/ui_icon_wip3d_ring1.png";
import ImgInner from "../content/decor/ui_icon_wip3d_PIN_1.png";
---

<div class="herorotate">
  <Image src={ImgBackground} alt="" class="herobg" />
  <Image src={ImgForeground} alt="" class="herofg rotate" />
  <Image src={ImgInner} alt="" class="heroinner grow bob" />
</div>

<style>
  .herorotate {
    display: grid;
    margin-top: 1em;
    margin-botton: 1em;
    margin-left: auto;
    margin-right: auto;
    grid-template-columns: 1fr;
    grid-template-rows: 1fr;
    max-width: 50%;
    max-height: 50%;
    align-content: center;
    align-self: center;
    filter: grayscale() contrast(1.1);
  }
  .herobg {
    grid-area: 1 / 1 / 1 /1;
    filter: drop-shadow(0 0 0.75rem black);
    filter: hue-rotate(60deg);
    z-index: 0;
  }
  .herofg {
    grid-area: 1 / 1 / 1 /1;
    max-width: 80%;
    max-height: 80%;
    align-self: center;
    align-items: center;
    justify-self: center;
    filter: drop-shadow(0 0 0.75rem var(--animborder));
    z-index: 2;
  }
  .heroinner {
    grid-area: 1 / 1 / 1 /1;
    max-width: 60%;
    max-height: 60%;
    align-self: center;
    align-items: center;
    justify-self: center;
    filter: drop-shadow(0 0 0.75rem var(--animborder));

    z-index: 3;
  }
</style>
