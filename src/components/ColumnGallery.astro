---
import { propsToFilename } from "astro/assets";
import { Image } from "astro:assets";

const imageMatches = import.meta.glob<{ default: ImageMetadata }>(
  "../gallery/dump2/*.{jpg,JPG,jpeg,png,PNG,webp}",
  { eager: true },
);

const imagesColumn1 = import.meta.glob<{ default: ImageMetadata }>(
  "../gallery/column1/*.{jpg,JPG,jpeg,png,PNG,webp}",
  { eager: true },
);

const Images3D = import.meta.glob<{ default: ImageMetadata }>(
  "../gallery/3d/*.{jpg,JPG,jpeg,png,PNG,webp}",
  { eager: true },
);

const ImagesIllustration = import.meta.glob<{ default: ImageMetadata }>(
  "../gallery/illustration/*.{jpg,JPG,jpeg,png,PNG,webp}",
  { eager: true },
);

const ImagesIndustrial = import.meta.glob<{ default: ImageMetadata }>(
  "../gallery/industrial/*.{jpg,JPG,jpeg,png,PNG,webp}",
  { eager: true },
);
const c1 = Object.values(Images3D);
const img3d = Object.values(Images3D);
const imgillustration = Object.values(ImagesIllustration);
const imgindustrial = Object.values(ImagesIndustrial);
---

