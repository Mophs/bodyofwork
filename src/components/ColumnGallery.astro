<style>
  :root {
    --gallery-gaps: 0.2em;
    --gallery-card-width: calc(30vw - var(var(--gallery-gaps)));
    --gallery-columns: 5; /* calc(vw / var(--gallery-card-width)); */
  }
  .column-gallery-frame {
    margin: 0 auto;
    margin-top: 1em;
    /* width: min(1200px, 100%); */
    /* columns: var(--gallery-columns) 10em; */
    /* column-width: min(calc(100vw / 5), 300px); */
    /* columns: 4 30%; */
    column-count: 5;
    column-gap: var(--gallery-gaps);
  }
  .column-gallery-image {
    display: block;
    line-height: var(--gallery-gaps);
    margin-bottom: var(--gallery-gaps);
    width: 100%;
    height: 100%;
    zindex: 100;
    -webkit-transition-property: all;
    -webkit-transition-duration: 0.3s;
    -webkit-transition-timing-function: ease;
  }

  hr {
    margin: 2em auto;
    width: 60%;
    color: var(--accent);
  }
  @media (max-width: 720px) {
    .column-gallery-frame {
      column-count: 3;
    }
  }
