<h2>3D</h2>
<div class="column-gallery-frame">
  {
    img3d.map((img) => (
      // <a href={img.default.src}>
      <Image
        src={img.default}
        alt=""
        width={img.default.width}
        height={img.default.height}
        class="column-gallery-image"
      />
      // </a>
    ))
  }
</div>

