import HeroAnimator from "../components/HeroAnimator.astro";
import footerimage from "../content/decor/site-footer.png";

import SideImage from "../content/decor/ui_icon_wip3d_side_wall_pearl.png";
import coverphotoSVG from "../content/decor/svg-cover-scroll.svg";

import Gallery from "../components/gallery.astro";
